# AstroAI Mobile — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# EXPO_PUBLIC_ prefix is required: Expo exposes only these vars to the JS bundle.
# Docs: https://docs.expo.dev/guides/environment-variables/

# Backend API URL
# iOS Simulator:          http://localhost:8000
# Android Emulator:       http://10.0.2.2:8000
# Real device (same LAN): http://192.168.x.x:8000
# Production:             https://astroai-api.production.com
EXPO_PUBLIC_API_URL=http://localhost:8000
